# =============================================
# Railway Deployment Environment Variables
# =============================================

# Option 1: Railway auto-injects this when you link a PostgreSQL service
# DATABASE_URL=postgresql://user:password@host:5432/dbname

# Option 2: Manual individual PostgreSQL variables (for local dev)
DB_HOST=localhost
DB_PORT=5432
DB_USER=proscient
DB_PASSWORD=proscient_secret
DB_NAME=proscient_db

# AI SERVICE CONFIGURATION (Cerebras Cloud SDK)
CEREBRAS_API_KEY=your_cerebras_api_key_here
